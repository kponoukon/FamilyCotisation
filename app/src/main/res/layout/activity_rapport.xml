<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="RÉSUMÉ" android:textSize="11sp" android:textColor="#888"
            android:letterSpacing="0.15" android:paddingBottom="10dp"/>

        <!-- Résumé cards -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="👥 Membres" android:textSize="14sp"/>
                <TextView android:id="@+id/tvResumeMembres" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textStyle="bold" android:textColor="#1A5276" android:textSize="15sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="💰 Total Cotisations" android:textSize="14sp"/>
                <TextView android:id="@+id/tvResumeCotisations" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 FCFA"
                    android:textStyle="bold" android:textColor="#1E8449" android:textSize="15sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="📤 Total Dépenses" android:textSize="14sp"/>
                <TextView android:id="@+id/tvResumeDepenses" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 FCFA"
                    android:textStyle="bold" android:textColor="#C0392B" android:textSize="15sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="10dp" app:cardElevation="3dp"
            app:cardBackgroundColor="#EBF5FB">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="📊 SOLDE" android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView android:id="@+id/tvResumeSolde" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 FCFA"
                    android:textStyle="bold" android:textSize="18sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bouton Export -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="EXPORT" android:textSize="11sp" android:textColor="#888"
            android:letterSpacing="0.15" android:paddingBottom="10dp"/>

        <Button
            android:id="@+id/btnExporterExcel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📊  Exporter en Excel (.xlsx)"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A5276"
            android:layout_marginBottom="12dp"/>

        <ProgressBar
            android:id="@+id/progressExport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Le fichier Excel sera généré avec 4 feuilles :\nRésumé · Membres · Cotisations · Dépenses"
            android:textSize="13sp"
            android:textColor="#888"
            android:gravity="center"
            android:paddingTop="8dp"/>

    </LinearLayout>
</ScrollView>
